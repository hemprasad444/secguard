      "targets": [{"datasource": {"type": "postgres", "uid": "PostgreSQL"}, "format": "table", "rawQuery": true, "rawSql": "SELECT f.raw_data->>'PkgName' AS package, f.raw_data->>'InstalledVersion' AS installed, f.raw_data->>'FixedVersion' AS fixed, f.cve_id AS cve, f.severity, ROUND(f.cvss_score::numeric, 1) AS cvss FROM findings f JOIN scans s ON s.id = f.scan_id WHERE s.config_json->>'scan_subtype' = 'dependency' AND f.severity IN ('critical','high') AND f.status NOT IN ('resolved','accepted','false_positive') ORDER BY f.cvss_score DESC NULLS LAST LIMIT 25", "refId": "A"}],
