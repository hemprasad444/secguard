      "targets": [{"datasource": {"type": "postgres", "uid": "PostgreSQL"}, "format": "table", "rawQuery": true, "rawSql": "SELECT REGEXP_REPLACE(s.config_json->>'target', '.*/', '') AS image, COUNT(*) FILTER (WHERE f.severity = 'critical') AS critical, COUNT(*) FILTER (WHERE f.severity = 'high') AS high, COUNT(*) FILTER (WHERE f.severity = 'medium') AS medium, COUNT(*) FILTER (WHERE f.severity = 'low') AS low FROM findings f JOIN scans s ON s.id = f.scan_id WHERE s.config_json->>'scan_subtype' = 'dependency' AND s.config_json->>'target' IS NOT NULL GROUP BY 1 ORDER BY COUNT(*) DESC LIMIT 15", "refId": "A"}],
