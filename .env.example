# ============================================================
# SecGuard - Environment Configuration
# ============================================================
# Copy this file to .env and update the values
# cp .env.example .env
# ============================================================

# Database
POSTGRES_USER=secguard
POSTGRES_PASSWORD=secguard_secret
POSTGRES_DB=secguard
DATABASE_URL=postgresql+asyncpg://secguard:secguard_secret@postgres:5432/secguard

# Redis
REDIS_URL=redis://redis:6379/0

# JWT - CHANGE THIS IN PRODUCTION
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost:8080

# Scanning Tools
TRIVY_SERVER_URL=http://trivy:4954
ZAP_API_URL=http://zap:8080
ZAP_API_KEY=change-me-zap-api-key

# Optional - External Integrations
SONARQUBE_URL=
SONARQUBE_TOKEN=
GITGUARDIAN_API_KEY=

# File uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=100
